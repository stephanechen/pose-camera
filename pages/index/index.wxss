/* pages/index/index.wxss */

.index-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f0f23 100%);
  padding: 0 40rpx;
  padding-top: env(safe-area-inset-top);
  padding-bottom: env(safe-area-inset-bottom);
  position: relative;
  overflow: hidden;
}

/* ==================== 顶部装饰 ==================== */
.header-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  overflow: hidden;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.3), rgba(255, 142, 142, 0.1));
}

.circle-1 {
  width: 400rpx;
  height: 400rpx;
  top: -150rpx;
  right: -100rpx;
}

.circle-2 {
  width: 300rpx;
  height: 300rpx;
  top: -100rpx;
  left: -80rpx;
  background: linear-gradient(135deg, rgba(78, 205, 196, 0.2), rgba(78, 205, 196, 0.05));
}

.circle-3 {
  width: 200rpx;
  height: 200rpx;
  top: 50rpx;
  right: 100rpx;
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.2), rgba(255, 215, 0, 0.05));
}

/* ==================== Logo区域 ==================== */
.logo-section {
  padding-top: 120rpx;
  text-align: center;
  margin-bottom: 60rpx;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  display: block;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  margin-bottom: 12rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  display: block;
}

/* ==================== 功能介绍 ==================== */
.features-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 24rpx;
}

.features-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feature-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.feature-num {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
  flex-shrink: 0;
}

.feature-content {
  flex: 1;
}

.feature-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  display: block;
  line-height: 1.4;
}

/* ==================== 功能特点 ==================== */
.highlights-section {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 60rpx;
}

.highlight-card {
  width: calc(50% - 8rpx);
  padding: 28rpx;
  background: rgba(255, 107, 107, 0.1);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border: 1rpx solid rgba(255, 107, 107, 0.2);
}

.highlight-card:nth-child(2),
.highlight-card:nth-child(4) {
  background: rgba(78, 205, 196, 0.1);
  border-color: rgba(78, 205, 196, 0.2);
}

.highlight-icon {
  font-size: 40rpx;
}

.highlight-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #ffffff;
}

/* ==================== 操作按钮 ==================== */
.action-section {
  margin-bottom: 40rpx;
}

.upload-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  border-radius: 50rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.4);
  transition: all 0.3s ease;
}

.upload-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.4);
}

.upload-icon {
  font-size: 40rpx;
}

.upload-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.quick-actions {
  display: flex;
  justify-content: center;
}

.quick-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 40rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  transition: all 0.3s ease;
}

.quick-btn:active {
  background: rgba(255, 255, 255, 0.15);
  transform: scale(0.98);
}

.quick-icon {
  font-size: 32rpx;
}

.quick-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ==================== 底部提示 ==================== */
.footer-tip {
  text-align: center;
  padding-bottom: 40rpx;
}

.footer-tip text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* ==================== 权限弹窗 ==================== */
.permission-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.permission-popup.show {
  opacity: 1;
  visibility: visible;
}

.permission-popup .popup-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
}

.permission-popup .popup-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 560rpx;
  background: #1e1e2e;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  transition: transform 0.3s ease;
}

.permission-popup.show .popup-content {
  transform: translate(-50%, -50%) scale(1);
}

.popup-icon {
  font-size: 80rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
  text-align: center;
  margin-bottom: 32rpx;
}

.popup-list {
  margin-bottom: 32rpx;
}

.popup-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.popup-item:last-child {
  border-bottom: none;
}

.item-icon {
  font-size: 36rpx;
}

.item-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.popup-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 20rpx;
}

.popup-btn:active {
  opacity: 0.9;
}

.popup-cancel {
  text-align: center;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  padding: 16rpx;
}

.popup-cancel:active {
  color: rgba(255, 255, 255, 0.8);
}
