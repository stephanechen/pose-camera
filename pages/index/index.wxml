<!--pages/index/index.wxml-->
<view class="index-page">
  <!-- 顶部装饰 -->
  <view class="header-decoration">
    <view class="deco-circle circle-1"></view>
    <view class="deco-circle circle-2"></view>
    <view class="deco-circle circle-3"></view>
  </view>

  <!-- Logo区域 -->
  <view class="logo-section">
    <view class="logo-icon">📸</view>
    <text class="app-name">透视取景器</text>
    <text class="app-slogan">小红书拍照参照神器</text>
  </view>

  <!-- 功能介绍 -->
  <view class="features-section">
    <view class="section-title">使用步骤</view>
    <view class="features-list">
      <view class="feature-item">
        <view class="feature-num">1</view>
        <view class="feature-content">
          <text class="feature-title">上传参考图</text>
          <text class="feature-desc">从相册选择或拍照上传小红书上的心仪照片</text>
        </view>
      </view>

      <view class="feature-item">
        <view class="feature-num">2</view>
        <view class="feature-content">
          <text class="feature-title">取景拍摄</text>
          <text class="feature-desc">参考透明图摆姿势，九宫格辅助构图</text>
        </view>
      </view>

      <view class="feature-item">
        <view class="feature-num">3</view>
        <view class="feature-content">
          <text class="feature-title">保存照片</text>
          <text class="feature-desc">拍出同款效果，记录美好瞬间</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 功能特点 -->
  <view class="highlights-section">
    <view class="highlight-card">
      <text class="highlight-icon">👁️</text>
      <text class="highlight-text">透明参考图</text>
    </view>
    <view class="highlight-card">
      <text class="highlight-icon">📐</text>
      <text class="highlight-text">九宫格构图</text>
    </view>
    <view class="highlight-card">
      <text class="highlight-icon">🔍</text>
      <text class="highlight-text">镜头缩放</text>
    </view>
    <view class="highlight-card">
      <text class="highlight-icon">✨</text>
      <text class="highlight-text">AI智能分割</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <view class="upload-btn" bindtap="onUploadReference">
      <text class="upload-icon">⬆️</text>
      <text class="upload-text">上传参考图开始</text>
    </view>

    <view class="quick-actions">
      <view class="quick-btn" bindtap="onTakePhotoDirect">
        <text class="quick-icon">📷</text>
        <text class="quick-text">直接拍照</text>
      </view>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tip">
    <text>上传小红书截图或相册照片作为拍摄参照</text>
  </view>

  <!-- 权限说明弹窗 -->
  <view class="permission-popup {{showPermission ? 'show' : ''}}" catchtouchmove="preventTouchMove">
    <view class="popup-mask" bindtap="hidePermission"></view>
    <view class="popup-content">
      <view class="popup-icon">📱</view>
      <view class="popup-title">需要以下权限</view>
      <view class="popup-list">
        <view class="popup-item">
          <text class="item-icon">📷</text>
          <text class="item-text">相机权限 - 用于拍照取景</text>
        </view>
        <view class="popup-item">
          <text class="item-icon">🖼️</text>
          <text class="item-text">相册权限 - 选择参考图</text>
        </view>
      </view>
      <view class="popup-btn" bindtap="requestPermission">授权并继续</view>
      <view class="popup-cancel" bindtap="hidePermission">稍后再说</view>
    </view>
  </view>
</view>
