/* pages/camera/camera.wxss - 原生相机风格 + 完整参考图功能（3:4比例） */
.camera-page {
  width:100vw; height:100vh; background:#000;
  display:flex; flex-direction:column; align-items:center;
  justify-content:center; position:relative; overflow:hidden;
}

/* 相机容器（3:4比例，居中显示） */
.camera-wrapper {
  width:100%; height:0; padding-bottom:133.33%; /* 3:4 = 75%宽高比，即高度是宽度的133.33% */
  position:relative; overflow:hidden; max-height:100vh;
}
.camera {
  position:absolute; top:0; left:0; width:100%; height:100%;
}

/* 对焦框 */
.focus-box{ position:absolute; width:80px; height:80px; border:2px solid #FFD700; pointer-events:none; z-index:99; }
.box-corner{ position:absolute; width:16px; height:16px; }
.tl{ top:-1px; left:-1px; border-top:3px solid #FFD700; border-left:3px solid #FFD700; }
.tr{ top:-1px; right:-1px; border-top:3px solid #FFD700; border-right:3px solid #FFD700; }
.bl{ bottom:-1px; left:-1px; border-bottom:3px solid #FFD700; border-left:3px solid #FFD700; }
.br{ bottom:-1px; right:-1px; border-bottom:3px solid #FFD700; border-right:3px solid #FFD700; }

/* 九宫格 - 标准三分法 */
.grid-overlay{ position:absolute; inset:0; pointer-events:none; z-index:10; }
.grid-line{ position:absolute; background:rgba(255,255,255,.4); }
.horizontal{ left:0; right:0; height:1px; }
.vertical{ top:0; bottom:0; width:1px; }

/* 参考图层 */
.reference-layer{ position:absolute; inset:0; pointer-events:auto; z-index:20; transition:opacity .15s ease; overflow:hidden; }
.reference-image{ width:100%; height:100%; transform-origin:center center; display:block; }

/* ==================== 顶部工具栏 ==================== */
.top-bar{
  position:fixed; top:env(safe-area-inset-top,44rpx); left:24rpx; right:24rpx;
  display:flex; align-items:center; justify-content:space-between;
  padding-top:8rpx; z-index:50;
}
.top-btn{
  min-width:72rpx; height:72rpx;
  background:rgba(0,0,0,.45); backdrop-filter:blur(10px);
  border-radius:50%;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  font-size:32rpx; color:#fff; transition:all .15s; gap:2rpx;
}
.top-btn:active{ transform:scale(.92); opacity:.7; }
.btn-label{ font-size:18rpx; line-height:1; }

.center-hint{
  font-size:24rpx; color:rgba(255,255,255,.6);
  text-align:center; max-width:300rpx; white-space:nowrap; overflow:hidden;text-overflow:ellipsis;
}

/* 缩放指示器 */
.zoom-indicator{
  position:absolute; top:45%; left:50%; transform:translate(-50%,-50%); z-index:30;
  background:rgba(0,0,0,.55); backdrop-filter:blur(6px); border-radius:16rpx;
  padding:14rpx 36rpx; font-size:38rpx; font-weight:700; color:#fff;
  pointer-events:none; animation:zoomFade 1.5s ease forwards;
}
@keyframes zoomFade{ 0%,70%{opacity:1} 100%{opacity:0;} }

/* ==================== 右侧控制面板 ==================== */
.right-controls{
  position:fixed; right:20rpx;
  /* 避免刘海遮挡，固定在屏幕中部偏下 */
  top:50%;
  transform:translateY(-20%);
  display:flex; flex-direction:column; gap:12rpx; z-index:40;
}
.right-btn{
  width:72rpx; min-height:72rpx;
  background:rgba(0,0,0,.65); backdrop-filter:blur(8px);
  border-radius:18rpx;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  font-size:22rpx; color:#fff; transition:all .15s;
  padding:8rpx 4rpx;
  border:1.5rpx solid rgba(255,255,255,0.25);
}
.right-btn:active{ transform:scale(.92); opacity:.8; }
.right-btn.active{ background:rgba(255,107,107,.9); color:#fff; border-color:rgba(255,255,255,0.5); }
.right-btn.danger{ background:rgba(220,60,60,.7); border-color:rgba(220,60,60,0.5); }
.right-label{ font-size:16rpx; opacity:.85; margin-top:2rpx; }
.opacity-btn{ gap:0; }
.opacity-value{ font-size:24rpx; font-weight:700; color:#FF6B6B; }

/* 翻转相机按钮 */
.switch-icon{
  font-size:36rpx; color:#fff; font-weight:300; line-height:1;
}

/* ==================== 上传引导提示（无参考图时） ==================== */
.upload-guide{
  position:absolute; top:40%; left:50%; transform:translate(-50%,-50%);
  z-index:30; width:80%; max-width:520rpx;
}
.guide-content{
  background:rgba(0,0,0,.65); backdrop-filter:blur(12px);
  border-radius:28rpx; padding:48rpx 36rpx; text-align:center;
  border:1px solid rgba(255,107,107,.4); animation:pulse 2.5s infinite;
}
.guide-icon{ font-size:72rpx; display:block; margin-bottom:20rpx; }
.guide-title{ font-size:34rpx; font-weight:600; color:#fff; display:block; margin-bottom:12rpx; }
.guide-desc{ font-size:24rpx; color:rgba(255,255,255,.6); display:block; margin-bottom:28rpx; line-height:1.4; }
.guide-btn{
  display:inline-flex; align-items:center; gap:12rpx;
  background:linear-gradient(135deg,#FF6B6B,#FF8E8E);
  padding:22rpx 44rpx; border-radius:40rpx;
  font-size:28rpx; font-weight:600; color:#fff; transition:.15s;
}
.guide-btn:active{ transform:scale(.95); }
.guide-arrow{ font-size:28rpx; }

@keyframes pulse{
  0%,100%{ box-shadow:0 0 0 0 rgba(255,107,107,.3); }
  50%{ box-shadow:0 0 20rpx 6rpx rgba(255,107,107,.15); }
}

/* ==================== 底部控制栏 ==================== */
.bottom-bar{
  position:fixed; bottom:0; left:0; right:0;
  height:240rpx; padding-bottom:env(safe-area-inset-bottom,34rpx);
  background:linear-gradient(to top,#000 72%,transparent 100%);
  display:flex; align-items:center; justify-content:space-between;
  padding-left:40rpx; padding-right:40rpx; z-index:50;
}

/* 上传参考图按钮（左侧，大按钮） */
.upload-main-btn{
  width:160rpx; height:84rpx;
  background:linear-gradient(135deg,#FF6B6B,#FF8E8E);
  border-radius:20rpx; display:flex; align-items:center; justify-content:center;
  gap:8rpx; flex-shrink:0; box-shadow:0 6rpx 20rpx rgba(255,107,107,.35); transition:.15s;
}
.upload-main-btn:active{ transform:scale(.94); }
.upload-icon{ font-size:32rpx; }
.upload-text{ font-size:22rpx; font-weight:600; color:#fff; }

/* 相册预览 */
.album-btn{
  width:84rpx; height:84rpx; border-radius:16rpx; overflow:hidden;
  border:2px solid rgba(255,255,255,.25); flex-shrink:0;
}
.album-thumb{ width:100%; height:100%; object-fit:cover; }
.ref-preview{ position:relative; border-color:rgba(255,107,107,.6); }
.ref-thumb{ opacity:.85; }
.ref-badge{
  position:absolute; bottom:0; left:0; right:0;
  background:rgba(255,107,107,.85);
  font-size:18rpx; color:#fff; text-align:center; padding:2rpx 0; font-weight:600;
}

/* ==================== 倍数切换器（苹果风格） ==================== */
.center-column{
  display:flex; flex-direction:column; align-items:center;
  gap:16rpx; flex-shrink:0;
}

.zoom-selector{
  display:flex; align-items:center; gap:4rpx;
  background:rgba(255,255,255,.2); border-radius:40rpx;
  padding:6rpx 10rpx;
}
.zoom-item{
  font-size:26rpx; font-weight:500; color:rgba(255,255,255,.7);
  padding:10rpx 16rpx; border-radius:30rpx;
  transition:all .15s ease;
  min-width:56rpx; text-align:center;
}
.zoom-item.active{
  background:#fff; color:#000; font-weight:700;
  box-shadow:0 2rpx 8rpx rgba(0,0,0,.25);
}
.zoom-item:active{ transform:scale(.95); }

/* 快门按钮 */
.shutter-wrapper{ display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.shutter-outer{
  width:120rpx; height:120rpx; border:5rpx solid #fff; border-radius:50%;
  display:flex; align-items:center; justify-content:center; transition:.15s;
}
.shutter-outer:active{ transform:scale(.93); }
.shutter-inner{ width:96rpx; height:96rpx; background:#fff; border-radius:50%; transition:background .15s; }
.shutter-wrapper:active .shutter-inner{ background:#ddd; }

/* 更多选项（网格开关） */
.more-options{ flex-shrink:0; display:flex; flex-direction:column; align-items:center; gap:4rpx; }
.option-icon{
  width:68rpx; height:68rpx; background:rgba(255,255,255,.15); border-radius:50%;
  display:flex; align-items:center; justify-content:center; font-size:32rpx; color:#fff; transition:.15s;
}
.option-icon:active{ transform:scale(.92); }
.option-icon.active{ background:rgba(255,215,0,.85); color:#000; }
.option-label{ font-size:20rpx; color:rgba(255,255,255,.55); }

/* ==================== 弹窗通用样式 ==================== */
.popup-mask{ position:fixed; inset:0; background:rgba(0,0,0,.55); z-index:199; }

.select-popup,
.transparency-popup{
  position:fixed; inset:0; z-index:200; visibility:hidden; opacity:0; transition:all .25s ease;
}
.select-popup.visible,
.transparency-popup.visible{ visibility:visible; opacity:1; }

.popup-content{
  position:absolute; bottom:0; left:0; right:0;
  background:#1a1a1a; border-top-left-radius:32rpx; border-top-right-radius:32rpx;
  padding:36rpx 32rpx; padding-bottom:calc(36rpx + env(safe-area-inset-bottom,34rpx));
  transform:translateY(100%); transition:transform .32s cubic-bezier(.4,0,.2,1);
}
.visible .popup-content{ transform:translateY(0); }

/* ==================== 上传参考图弹窗 ==================== */
.select-panel{ padding:28rpx 32rpx; }
.select-header{
  font-size:34rpx; font-weight:600; color:#fff; text-align:center; margin-bottom:28rpx;
}
.select-option{
  display:flex; align-items:center; padding:26rpx 24rpx; margin-bottom:16rpx;
  background:rgba(255,255,255,.07); border-radius:18rpx; transition:.15s;
}
.select-option:last-of-type{ margin-bottom:0; }
.select-option:active{ background:rgba(255,255,255,.12); }
.opt-icon{ font-size:44rpx; margin-right:20rpx; flex-shrink:0; }
.opt-text{ font-size:30rpx; color:#fff; flex:1; }
.opt-desc{ font-size:22rpx; color:rgba(255,255,255,.45); flex:1; }
.select-cancel{
  text-align:center; font-size:28rpx; color:rgba(255,255,255,.45);
  padding:24rpx 0; margin-top:8rpx; border-top:1rpx solid rgba(255,255,255,.06);
}

/* ==================== 透明度调节面板 ==================== */
.transparency-panel-content{ padding:36rpx 32rpx; }
.tp-header{
  display:flex; justify-content:space-between; align-items:center; margin-bottom:24rpx;
}
.tp-title{ font-size:32rpx; font-weight:600; color:#fff; }
.tp-value{ font-size:38rpx; font-weight:700; color:#FF6B6B; }

.ref-preview-mini{
  width:200rpx; height:267rpx; border-radius:12rpx; overflow:hidden;
  border:2rpx solid rgba(255,107,107,.4); margin:0 auto 24rpx;
}
.ref-preview-mini image{ width:100%; height:100%; object-fit:cover; }

.preset-row{
  display:flex; flex-wrap:wrap; gap:12rpx; margin-top:24rpx; justify-content:center;
}
.preset-item{
  min-width:76rpx; height:56rpx; padding:0 16rpx;
  background:rgba(255,255,255,.08); border-radius:28rpx;
  display:flex; align-items:center; justify-content:center;
  font-size:24rpx; color:rgba(255,255,255,.7); transition:.15s;
}
.preset-item.active{ background:rgba(255,107,107,.85); color:#fff; font-weight:600; }
.preset-item:active{ transform:scale(.94); }

.tp-actions-row{
  display:flex; justify-content:center; gap:24rpx; margin-top:28rpx;
  padding-top:24rpx; border-top:1rpx solid rgba(255,255,255,.08);
}
.tp-action-btn{
  display:flex; flex-direction:column; align-items:center; gap:6rpx;
  padding:16rpx 20rpx; border-radius:16rpx;
  background:rgba(255,255,255,.06); transition:.15s;
}
.tp-action-btn:active{ transform:scale(.95); background:rgba(255,255,255,.1); }
.tp-action-btn text:nth-child(1){ font-size:32rpx; }
.tp-action-btn text:nth-child(2){ font-size:22rpx; color:rgba(255,255,255,.6); }
.tp-action-btn.danger{ background:rgba(220,60,60,.15); }

.tp-close{
  text-align:center; font-size:28rpx; color:rgba(255,255,255,.5);
  padding:24rpx 0; margin-top:8rpx; border-top:1rpx solid rgba(255,255,255,.05);
}

/* ==================== 滑块容器 ==================== */
.slider-container{ padding:0 8rpx; margin:4rpx 0; }
