/* pages/preview/preview.wxss */
.page{ width:100vw; height:100vh; background:#000; position:relative; overflow:hidden; }
.photo{ width:100%; height:100%; object-fit:contain; }

.top-bar{
  position:fixed; top:env(safe-area-inset-top,44rpx); left:24rpx; right:24rpx;
  display:flex; align-items:center; justify-content:space-between; z-index:50;
}
.close-btn{
  font-size:40rpx; color:#fff; padding:12rpx 20rpx;
}
.title{ font-size:32rpx; font-weight:600; color:#fff;}

.bottom-bar{
  position:fixed; bottom:0; left:0; right:0;
  display:flex; gap:24rpx; justify-content:center;
  padding:36rpx 48rpx; padding-bottom:calc(36rpx + env(safe-area-inset-bottom,34rpx));
  background:linear-gradient(to top,#000 60%,transparent);
  z-index:50;
}
.btn{
  min-width:240rpx; height:80rpx; border-radius:40rpx;
  display:flex; align-items:center; justify-content:center;
  font-size:30rpx; font-weight:500; transition:.15s;
}
.btn:active{ transform:scale(.96); }
.retake{ background:rgba(255,255,255,.15); color:#fff;}
.save{ background:#FFD700; color:#000; font-weight:600;}
.saved-text{ background:rgba(50,200,120,.85); color:#fff;}

.loading-mask{
  position:fixed; inset:0;
  background:rgba(0,0,0,.7);
  display:flex; align-items:center; justify-content:center;
  z-index:99; font-size:28rpx; color:#fff;
}