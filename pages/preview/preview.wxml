<!--pages/preview/preview.wxml - 简洁预览页 -->
<view class="page">
  <!-- 全屏图片 -->
  <image
    class="photo"
    src="{{photoPath}}"
    mode="aspectFit"
    binderror="onImageError"
  />

  <!-- 顶部栏 -->
  <view class="top-bar">
    <text class="close-btn" bindtap="goBack">✕</text>
    <text class="title">照片预览</text>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="btn retake" bindtap="retakePhoto">重拍</view>
    <view class="btn save" bindtap="savePhoto" wx:if="{{!saved}}">保存到相册</view>
    <text class="btn saved-text" wx:if="{{saved}}">✓ 已保存</text>
  </view>

  <!-- 保存中 -->
  <view class="loading-mask" wx:if="{{saving}}">
    <text>保存中...</text>
  </view>
</view>
